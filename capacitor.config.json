{
  "appId": "fr.saufimprevu.app",
  "appName": "myPlace",
  "webDir": "public",
  "server": {
    "url": "https://www.myplace.coach",
    "cleartext": false,
    "allowNavigation": [
      "openid.mysafe.services",
      "*.mysafe.services",
      "mysafe.services"
    ]
  },
  "ios": {
    "contentInset": "always",
    "allowsLinkPreview": false
  },
  "plugins": {
    "SocialLogin": {
      "providers": {
        "google": false,
        "facebook": false,
        "apple": true,
        "twitter": false
      }
    }
  }
}
